{
  "sourceLanguage" : "ar",
  "strings" : {
    "" : {

    },
    "%lld%%" : {

    },
    "أتممت رحلتك بنجاح!\nهذا الإيقاع المنضبط حفّز العصب الحائر لديك، مما خفض استجابة جسدك للتوتر وأعاد توازن مؤشراتك الحيوية بشكل فسيولوجي." : {
      "localizations" : {
        "en" : {
          "variations" : {
            "device" : {
              "iphone" : {
                "stringUnit" : {
                  "state" : "needs_review",
                  "value" : "You have successfully completed your journey!\nThis steady rhythm has stimulated your vagus nerve, reducing your body's stress response and physiologically restoring the balance of your vital signs."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "You have successfully completed your journey!\nThis steady rhythm has stimulated your vagus nerve, reducing your body's stress response and physiologically restoring the balance of your vital signs."
                }
              }
            }
          }
        }
      }
    },
    "أطلق صوتك لتهدأ روحك. هذه الرحلة صُممت لتكون صدى مشاعرك؛ ننسجُ من صوتك وصوت البحر لحناً يبدد شتات النفس، ويصل بك إلى مرسى الأمان." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "variations" : {
            "device" : {
              "iphone" : {
                "stringUnit" : {
                  "state" : "needs_review",
                  "value" : "Release your voice to calm your soul. This journey is crafted as an echo of your feelings; we weave from your voice and the sea’s song a melody that scatters the mind’s unrest and brings you to the harbor of peace."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Release your voice to calm your soul. This journey is crafted as an echo of your feelings; we weave from your voice and the sea’s song a melody that scatters the mind’s unrest and brings you to the harbor of peace."
                }
              }
            }
          }
        }
      }
    },
    "إذا أردت المغادرة، يمكنك إنهاء الجلسة في أي وقت عبر زر العودة في الأعلى." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you want to leave, you can end the session anytime using the back button at the top.\n"
          }
        }
      }
    },
    "اجعل حركة القارب دليلاً لأنفاسك" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Make the movement of the boat follow the rhythm of your breathing.\n"
          }
        }
      }
    },
    "اختر سفينتك للرحلة" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "variations" : {
            "device" : {
              "iphone" : {
                "stringUnit" : {
                  "state" : "needs_review",
                  "value" : "Choose your vessel for the journey\n"
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Choose your vessel for the journey\n"
                }
              }
            }
          }
        }
      }
    },
    "اضغط الشاشة لرؤية مدى تقدمك في الرحلة" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the screen to see your progress in the journey.\n"
          }
        }
      }
    },
    "العودة للمرفأ" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Return to the harbor"
          }
        }
      }
    },
    "خذ استراحة من ضجيج التغيير. هذه\nالرحلة صُممت لتكون مساحتك الخاصة،\nحيث تحول اضطراب المشاعر إلى أنفاس\nهادئة تصل بك إلى بر الأمان." : {
      "localizations" : {
        "en" : {
          "variations" : {
            "device" : {
              "iphone" : {
                "stringUnit" : {
                  "state" : "needs_review",
                  "value" : "Take a pause from the noise of change. This journey is designed to be your private space, where the turmoil of feelings turns into calm breaths that carry you to safe shores."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Take a pause from the noise of change. This journey is designed to be your private space, where the turmoil of feelings turns into calm breaths that carry you to safe shores."
                }
              }
            }
          }
        }
      }
    },
    "خذ استراحة من ضجيج التغيير. هذه الرحلة صُممت لتكون مساحتك الخاصة، حيث تحول اضطراب المشاعر إلى أنفاس هادئة تصل بك إلى بر الأمان." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take a pause from the noise of change. This journey is designed to be your private space, where the turmoil of feelings turns into calm breaths that carry you to safe shores."
          }
        }
      }
    },
    "خذ شهيقاً مع صعوده" : {
